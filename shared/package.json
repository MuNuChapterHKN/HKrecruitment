{
  "name": "@hkrecruitment/shared",
  "private": "true",
  "type": "commonjs",
  "description": "Shared types and schemas",
  "main": "src/index",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "test": "jest -i --verbose"
  },
  "devDependencies": {
    "@types/jest": "28.1.8",
    "jest": "28.1.3",
    "prettier": "^2.8.5",
    "ts-jest": "28.0.8",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "@casl/ability": "^6.3.3",
    "joi": "^17.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
