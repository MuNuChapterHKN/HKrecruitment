{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es6",
    "lib": ["es6"],
    "types": ["reflect-metadata"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "inlineSourceMap": true,
    "esModuleInterop": true
  },
  "exclude": [
    "test",
    "src/modules",
    "src/config"
  ]
}
